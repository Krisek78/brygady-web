function setupEventListeners() {
    // 1. Wybór budowy
    const buildingSelect = document.getElementById('buildingSelect');
    if (buildingSelect) {
        buildingSelect.onchange = (e) => selectProject(e.target.value);
    }

    // 2. Dodawanie zespołu (WAŻNE: używamy funkcji anonimowej () => )
    const btnAddTeam = document.getElementById('btnAddTeam');
    if (btnAddTeam) {
        btnAddTeam.onclick = () => addTeam();
    }

    // 3. Dodawanie budowy (WAŻNE: tutaj często powstaje błąd wywołania)
    const btnAddBuilding = document.getElementById('btnAddBuilding');
    if (btnAddBuilding) {
        btnAddBuilding.onclick = () => {
            openTextModal('Dodaj budowę', 'Nazwa nowej budowy', (name) => {
                addProject(name);
            });
        };
    }

    // 4. Usuwanie i edycja budowy
    const btnDeleteBuilding = document.getElementById('btnDeleteBuilding');
    if (btnDeleteBuilding) {
        btnDeleteBuilding.onclick = () => deleteCurrentProject();
    }

    const btnEditBuilding = document.getElementById('btnEditBuilding');
    if (btnEditBuilding) {
        btnEditBuilding.onclick = () => editProjectName();
    }

    const btnResetProject = document.getElementById('btnResetProject');
    if (btnResetProject) {
        btnResetProject.onclick = () => resetProject();
    }

    // 5. Filtrowanie (NOWE)
    const workerSearch = document.getElementById('workerSearch');
    if (workerSearch) {
        workerSearch.addEventListener('input', filterWorkers);
    }

    // 6. Formularze (Enter w polach tekstowych)
    const wmName = document.getElementById('wmName');
    if (wmName) {
        wmName.onkeypress = (e) => { if(e.key === 'Enter') saveWorker(); };
    }

    const taskInput = document.getElementById('taskInput');
    if (taskInput) {
        taskInput.onkeypress = (e) => { if(e.key === 'Enter') addTaskFromInput(); };
    }
}


async function addProject(n) {
    await fetch('api/projects.php', { method: 'POST', body: JSON.stringify({ name: n }) });
    loadData();
}

function openTextModal(title, label, cb) {
    document.getElementById('textModalTitle').textContent = title;
    document.getElementById('textModalOk').onclick = () => { cb(document.getElementById('textModalInput').value); closeModal('textModal'); };
    openModal('textModal');
}
